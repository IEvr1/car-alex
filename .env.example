# Vercel Blob — δημιουργήστε store από Vercel Dashboard → Storage → Blob
# Αποθηκεύει φωτογραφίες + metadata.json ανά αυτοκίνητο
BLOB_READ_WRITE_TOKEN=

# Admin panel — κωδικός σύνδεσης (τουλάχιστον 8 χαρακτήρες)
ADMIN_PASSWORD=

# Session cookie signing — τυχαίο string τουλάχιστον 32 χαρακτήρες
SESSION_SECRET=

# Δημόσια επικοινωνία (εμφανίζονται στο site)
NEXT_PUBLIC_CONTACT_PHONE=+30 210 1234567
NEXT_PUBLIC_CONTACT_EMAIL=info@caralex.gr
